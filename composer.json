{
    "name": "kode/session",
    "description": "kode/session - 分布式会话管理器，支持文件、Redis等驱动",
    "license": "Apache-2.0",
    "version": "1.0.1",
    "type": "library",
    "keywords": [
        "session",
        "cache",
        "distributed",
        "redis",
        "file",
        "kode"
    ],
    "authors": [
        {
            "name": "kode",
            "email": "382601296@qq.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "predis/predis": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Kode\\Session\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kode\\Session\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
